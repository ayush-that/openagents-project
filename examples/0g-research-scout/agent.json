{
  "name": "0G Research Scout",
  "description": "A portable OpenClaw-style agent that researches a topic, reasons through 0G Compute, and persists memory/log artifacts to 0G Storage.",
  "model": "0g/openai/gpt-oss-20b",
  "providers": {
    "0g": {
      "apiBase": "https://router-api.0g.ai/v1",
      "apiKey": "env:OG_API_KEY",
      "apiType": "openai-chat",
      "authType": "bearer-token",
      "models": [
        {
          "id": "openai/gpt-oss-20b",
          "name": "openai/gpt-oss-20b",
          "input": ["text"],
          "contextWindow": 128000,
          "maxTokens": 8192
        }
      ]
    }
  },
  "storage": {
    "network": "0g-storage",
    "packageUri": "0g://package/{rootHash}",
    "memoryUri": "0g://memory/{agentId}/MEMORY.md",
    "logUri": "0g://logs/{agentId}/{sessionId}.jsonl"
  }
}
